generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pedido {
  id          Int      @id @default(autoincrement())
  nombre      String
  email       String
  empresa     String
  descripcion String
  fecha       DateTime @default(now())
  estado      String   @default("nuevo")
  notas       String   @default("")
}
